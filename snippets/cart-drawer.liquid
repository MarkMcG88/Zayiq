<div class="cart-drawer" id="CartDrawer" aria-hidden="true" role="dialog" aria-label="Shopping cart">
  <div class="cart-drawer__overlay" data-cart-drawer-close></div>
  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart <span class="cart-drawer__count">({{ cart.item_count }})</span></h2>
      <button class="cart-drawer__close" data-cart-drawer-close aria-label="Close cart">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    {% assign free_shipping_threshold = 10000 %}
    {% assign cart_total = cart.total_price %}
    {% assign shipping_remaining = free_shipping_threshold | minus: cart_total %}

    <div class="cart-drawer__shipping-bar">
      {% if cart_total >= free_shipping_threshold %}
        <p class="cart-drawer__shipping-text">You've unlocked <strong>free shipping!</strong></p>
        <div class="cart-drawer__shipping-progress">
          <div class="cart-drawer__shipping-fill" style="width: 100%;"></div>
        </div>
      {% else %}
        <p class="cart-drawer__shipping-text">
          Add <strong>{{ shipping_remaining | money }}</strong> more for free shipping
        </p>
        <div class="cart-drawer__shipping-progress">
          {% assign progress = cart_total | times: 100 | divided_by: free_shipping_threshold %}
          <div class="cart-drawer__shipping-fill" style="width: {{ progress }}%;"></div>
        </div>
      {% endif %}
    </div>

    <div class="cart-drawer__body">
      {% if cart.item_count == 0 %}
        <div class="cart-drawer__empty">
          <p>Your cart is empty</p>
          <a href="/collections/all" class="btn btn--primary" data-cart-drawer-close>Start Shopping</a>
        </div>
      {% else %}
        <form action="/cart" method="post" id="CartDrawerForm">
          {% for item in cart.items %}
            <div class="cart-drawer__item">
              <a href="{{ item.url }}" class="cart-drawer__item-image">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy" width="80" height="100">
                {% endif %}
              </a>
              <div class="cart-drawer__item-info">
                <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
                {% endif %}
                <p class="cart-drawer__item-price">{{ item.price | money }}</p>
                <div class="cart-drawer__item-qty">
                  <button type="button" class="cart-drawer__qty-btn" data-action="decrease" data-line="{{ forloop.index }}" aria-label="Decrease quantity">-</button>
                  <span class="cart-drawer__qty-value">{{ item.quantity }}</span>
                  <button type="button" class="cart-drawer__qty-btn" data-action="increase" data-line="{{ forloop.index }}" aria-label="Increase quantity">+</button>
                </div>
              </div>
              <button type="button" class="cart-drawer__item-remove" data-line="{{ forloop.index }}" data-action="remove" aria-label="Remove {{ item.title }}">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
          {% endfor %}
        </form>
      {% endif %}
    </div>

    {% if cart.item_count > 0 %}
      <div class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__footer-note">Shipping & taxes calculated at checkout</p>
        <button type="submit" name="checkout" form="CartDrawerForm" class="btn btn--primary btn--large cart-drawer__checkout">
          Checkout
        </button>
        <a href="/cart" class="cart-drawer__view-cart" data-cart-drawer-close>View Full Cart</a>
      </div>
    {% endif %}
  </div>
</div>
