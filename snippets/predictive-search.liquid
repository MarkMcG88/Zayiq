<div class="predictive-search" id="PredictiveSearch" aria-hidden="true">
  <div class="predictive-search__overlay" data-search-close></div>
  <div class="predictive-search__panel">
    <div class="predictive-search__header">
      <form action="/search" method="get" class="predictive-search__form" role="search">
        <svg class="predictive-search__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="search"
          name="q"
          id="PredictiveSearchInput"
          class="predictive-search__input"
          placeholder="Search products, artists, stories..."
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label="Search"
        >
        <button type="button" class="predictive-search__close" data-search-close aria-label="Close search">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </form>
    </div>
    <div class="predictive-search__results" id="PredictiveSearchResults">
      <div class="predictive-search__loading" style="display: none;">
        <div class="predictive-search__spinner"></div>
      </div>
      <div class="predictive-search__content"></div>
    </div>
  </div>
</div>
