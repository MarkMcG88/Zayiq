  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading font",
        "default": "space_grotesk_n4",
        "info": "Used for all headings, titles, and labels"
      },
      {
        "type": "select",
        "id": "heading_weight",
        "label": "Heading weight",
        "default": "700",
        "options": [
          { "value": "400", "label": "Regular" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi-bold" },
          { "value": "700", "label": "Bold" }
        ]
      },
      {
        "type": "select",
        "id": "heading_transform",
        "label": "Heading letter case",
        "default": "uppercase",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "UPPERCASE" },
          { "value": "lowercase", "label": "lowercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ]
      },
      {
        "type": "header",
        "content": "Body text"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "inter_n4",
        "info": "Used for paragraphs, descriptions, and UI text"
      },
      {
        "type": "range",
        "id": "body_font_size",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      },
      {
        "type": "select",
        "id": "body_line_height",
        "label": "Body line height",
        "default": "1.6",
        "options": [
          { "value": "1.2", "label": "Tight (1.2)" },
          { "value": "1.4", "label": "Compact (1.4)" },
          { "value": "1.6", "label": "Normal (1.6)" },
          { "value": "1.8", "label": "Relaxed (1.8)" },
          { "value": "2.0", "label": "Spacious (2.0)" }
        ]
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "header",
        "content": "Page width"
      },
      {
        "type": "range",
        "id": "max_page_width",
        "label": "Maximum page width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "default": 1440
      },
      {
        "type": "header",
        "content": "Spacing"
      },
      {
        "type": "range",
        "id": "section_vertical_spacing",
        "label": "Vertical space between sections",
        "min": 20,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 60,
        "info": "Top and bottom padding for each section"
      },
      {
        "type": "range",
        "id": "grid_gap",
        "label": "Grid gap",
        "min": 8,
        "max": 40,
        "step": 4,
        "unit": "px",
        "default": 20,
        "info": "Space between product cards, collection items, etc."
      }
    ]
  },
  {
    "name": "Buttons & styles",
    "settings": [
      {
        "type": "header",
        "content": "Buttons"
      },
      {
        "type": "select",
        "id": "button_style",
        "label": "Button style",
        "default": "square",
        "options": [
          { "value": "square", "label": "Square corners" },
          { "value": "rounded", "label": "Slightly rounded" },
          { "value": "pill", "label": "Pill shape" }
        ]
      },
      {
        "type": "select",
        "id": "button_transform",
        "label": "Button letter case",
        "default": "uppercase",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "UPPERCASE" },
          { "value": "capitalize", "label": "Capitalize" }
        ]
      },
      {
        "type": "header",
        "content": "Cards & surfaces"
      },
      {
        "type": "select",
        "id": "card_border_radius",
        "label": "Card corner radius",
        "default": "small",
        "options": [
          { "value": "none", "label": "Square (0px)" },
          { "value": "small", "label": "Small (4px)" },
          { "value": "medium", "label": "Medium (8px)" },
          { "value": "large", "label": "Large (12px)" }
        ]
      },
      {
        "type": "checkbox",
        "id": "card_shadow",
        "label": "Show shadow on cards",
        "default": false
      },
      {
        "type": "header",
        "content": "Animations"
      },
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable animations",
        "default": true,
        "info": "Hover effects, scroll transitions, and page load animations"
      },
      {
        "type": "select",
        "id": "animation_speed",
        "label": "Animation speed",
        "default": "normal",
        "options": [
          { "value": "fast", "label": "Fast" },
          { "value": "normal", "label": "Normal" },
          { "value": "slow", "label": "Slow" }
        ]
      }
    ]
  },
  {
    "name": "Logo & favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "Displayed in the header and other brand areas"
