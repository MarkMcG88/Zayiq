      {
        "type": "checkbox",
        "id": "search_show_collections",
        "label": "Show collection suggestions",
        "default": true
      },
      {
        "type": "range",
        "id": "search_results_limit",
        "label": "Max suggestions",
        "min": 2,
        "max": 10,
        "step": 1,
        "default": 6
      }
    ]
