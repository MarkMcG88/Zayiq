<section class="blog-posts section-padding">
  <div class="page-width">
    <div class="blog-posts__header">
      <h2>{{ section.settings.title | default: 'Artist' }} <span style="color: var(--color-primary);">{{ section.settings.title_highlight | default: 'Stories' }}</span></h2>
      {% if section.settings.link_text != blank %}
        <a href="{{ blogs[section.settings.blog].url | default: '/blogs/artists' }}" class="btn btn--outline">
          {{ section.settings.link_text }}
        </a>
      {% endif %}
    </div>

    <div class="grid grid--3">
      {% if section.settings.blog != blank and blogs[section.settings.blog].articles.size > 0 %}
        {% for article in blogs[section.settings.blog].articles limit: section.settings.posts_to_show %}
          <a href="{{ article.url }}" class="blog-card">
            {% if article.image %}
              <div class="blog-card__media">
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | default: article.title }}"
                  loading="lazy"
                  width="800"
                  height="500"
                >
              </div>
            {% endif %}

            {% if article.tags.size > 0 %}
              <span class="blog-card__tag">{{ article.tags.first }}</span>
            {% endif %}

            <h3 class="blog-card__title">{{ article.title }}</h3>
            <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
            <p class="blog-card__meta">{{ article.published_at | date: '%B %d, %Y' }}</p>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <div class="blog-card">
            <div class="blog-card__media">
              {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <span class="blog-card__tag">Artist Interview</span>
            <h3 class="blog-card__title">Behind the Collection: Artist Name</h3>
            <p class="blog-card__excerpt">A glimpse into the creative process behind our latest artist collaboration...</p>
            <p class="blog-card__meta">April 7, 2026</p>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Artist"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Title highlight word",
      "default": "Stories"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "All Stories"
    }
  ],
  "presets": [
    {
      "name": "Blog posts"
    }
  ]
}
{% endschema %}
