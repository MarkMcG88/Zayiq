<section class="newsletter section-padding">
  <div class="page-width">
    <h2 class="newsletter__title">{{ section.settings.heading | default: 'Join the Collective' }}</h2>
    <p class="newsletter__text">{{ section.settings.text | default: 'Be first to know about new artist drops, exclusive pieces, and behind-the-scenes stories.' }}</p>

    {% form 'customer' %}
      <div class="newsletter__form">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="newsletter__input"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
          required
          autocomplete="email"
          aria-label="Email address"
        >
        <button type="submit" class="newsletter__submit">
          {{ section.settings.button_text | default: 'Subscribe' }}
        </button>
      </div>

      {% if form.posted_successfully? %}
        <p style="margin-top: 16px; color: var(--color-accent);">You're in. Welcome to the collective.</p>
      {% endif %}

      {% if form.errors %}
        <p style="margin-top: 16px; color: var(--color-primary);">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Collective"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Be first to know about new artist drops, exclusive pieces, and behind-the-scenes stories."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
