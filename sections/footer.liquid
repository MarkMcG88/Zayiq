<footer class="footer" role="contentinfo" style="background: #1A1A1A; color: #FFFFFF;">
  <div class="page-width">
    <div class="footer__grid">
      <div class="footer__brand">
        <p class="footer__brand-name">ZAY<span style="color: #FF3C00;">IQ</span></p>
        <p class="footer__brand-desc">{{ section.settings.description | default: 'Bold apparel designed by independent artists. Every piece tells a story.' }}</p>
        <div class="footer__social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg>
            </a>
          {% endif %}
          {% if settings.social_twitter != blank %}
            <a href="{{ settings.social_twitter }}" aria-label="X / Twitter" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M4 4l6.5 8L4 20h2l5.5-6.5L16 20h4l-6.5-8L20 4h-2l-5.5 6.5L8 4H4z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }}>
            <h4 class="footer__heading">{{ block.settings.heading }}</h4>
            <ul class="footer__links">
              {% assign menu = linklists[block.settings.menu] %}
              {% if menu != blank %}
                {% for link in menu.links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              {% endif %}
            </ul>
          </div>
        {% endfor %}
      {% else %}
        <div>
          <h4 class="footer__heading">Shop</h4>
          <ul class="footer__links">
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/collections">Collections</a></li>
          </ul>
        </div>
        <div>
          <h4 class="footer__heading">Company</h4>
          <ul class="footer__links">
            <li><a href="/pages/about">About Us</a></li>
            <li><a href="/blogs/artists">Artist Blog</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4 class="footer__heading">Support</h4>
          <ul class="footer__links">
            <li><a href="/pages/shipping">Shipping & Returns</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/size-guide">Size Guide</a></li>
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          </ul>
        </div>
      {% endif %}
    </div>

    <div class="footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p>{{ powered_by_link }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Bold apparel designed by independent artists. Every piece tells a story."
    }
  ]
}
{% endschema %}
