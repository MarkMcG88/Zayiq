<header class="header" role="banner">
  <div class="header__inner">
    <a href="/" class="header__logo">
      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="200"
          height="auto"
          loading="eager"
        >
      {% else %}
        ZAY<span>IQ</span>
      {% endif %}
    </a>

    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      {% for link in linklists[section.settings.menu].links %}
        {% if link.links.size > 0 %}
          <div class="header__dropdown">
            <a href="{{ link.url }}" class="header__dropdown-trigger">
              {{ link.title }}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <div class="header__dropdown-menu">
              <div class="header__dropdown-inner">
                <div class="header__dropdown-nav">
                  {% for child_link in link.links %}
                    <div class="header__dropdown-column">
                      {% if child_link.links.size > 0 %}
                        <p class="header__dropdown-heading">{{ child_link.title }}</p>
                        <ul class="header__dropdown-links">
                          {% for grandchild_link in child_link.links %}
                            <li><a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a></li>
                          {% endfor %}
                        </ul>
                      {% else %}
                        <ul class="header__dropdown-links">
                          <li><a href="{{ child_link.url }}" class="header__dropdown-link--featured">{{ child_link.title }}</a></li>
                        </ul>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>

                {% assign link_handle = link.title | handleize %}
                {% assign has_feature = false %}
                {% for block in section.blocks %}
                  {% if block.type == 'menu_feature' and block.settings.menu_item == link_handle %}
                    {% assign has_feature = true %}
                    <div class="header__dropdown-feature" {{ block.shopify_attributes }}>
                      <a href="{{ block.settings.link | default: link.url }}" class="header__dropdown-feature-card">
                        {% if block.settings.image != blank %}
                          <div class="header__dropdown-feature-img">
                            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.heading | default: link.title }}" loading="lazy">
                          </div>
                        {% endif %}
                        {% if block.settings.heading != blank %}
                          <p class="header__dropdown-feature-text">{{ block.settings.heading }}</p>
                        {% endif %}
                        {% if block.settings.cta_text != blank %}
                          <p class="header__dropdown-feature-cta">{{ block.settings.cta_text }} <span>&rarr;</span></p>
                        {% endif %}
                      </a>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        {% else %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="header__actions">
      <a href="/search" class="header__action-icon" aria-label="Search" data-search-open>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </a>
      <a href="/account" class="header__action-icon" aria-label="Account">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a href="/cart" class="header__action-icon header__action-icon--cart" aria-label="Cart" data-cart-drawer-open>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>

      <button type="button" class="header__menu-toggle" aria-label="Menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ],
  "blocks": [
    {
      "type": "menu_feature",
      "name": "Menu feature image",
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "Menu item handle",
          "info": "The lowercase, hyphenated version of the nav item name (e.g. 'shop' or 'artists')"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Featured image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "New Arrivals"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Call to action text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}
