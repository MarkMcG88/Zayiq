<header class="header" role="banner">
  <div class="header__inner">
    <a href="/" class="header__logo">
      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="200"
          height="auto"
          loading="eager"
        >
      {% else %}
        ZAY<span>IQ</span>
      {% endif %}
    </a>

    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      {% for link in linklists[section.settings.menu].links %}
        {% if link.links.size > 0 %}
          <div class="header__dropdown">
            <a href="{{ link.url }}" class="header__dropdown-trigger">
              {{ link.title }}
              <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <div class="header__dropdown-menu">
              <div class="header__dropdown-inner">
                {% for child_link in link.links %}
                  {% if child_link.links.size > 0 %}
                    <div class="header__dropdown-column">
                      <p class="header__dropdown-heading">{{ child_link.title }}</p>
                      <ul class="header__dropdown-links">
                        {% for grandchild_link in child_link.links %}
                          <li><a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a></li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% else %}
                    <div class="header__dropdown-column">
                      <ul class="header__dropdown-links">
                        <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                      </ul>
                    </div>
                  {% endif %}
                {% endfor %}

                {% if section.settings.dropdown_image != blank %}
                  <div class="header__dropdown-feature">
                    <img
                      src="{{ section.settings.dropdown_image | image_url: width: 400 }}"
                      alt="{{ section.settings.dropdown_image_text | default: 'Featured' }}"
                      loading="lazy"
                      width="400"
                      height="300"
                    >
                    {% if section.settings.dropdown_image_text != blank %}
                      <p class="header__dropdown-feature-text">{{ section.settings.dropdown_image_text }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% else %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="header__icons">
      <button type="button" class="header__icon" data-search-open aria-label="Search" title="Search">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <a href="/account" class="header__icon" aria-label="Account" title="Account">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <button type="button" class="header__icon header__icon--cart" data-cart-drawer-open aria-label="Cart" title="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </button>

      <button type="button" class="header__menu-toggle" aria-label="Menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "dropdown_image",
      "label": "Dropdown featured image"
    },
    {
      "type": "text",
      "id": "dropdown_image_text",
      "label": "Dropdown image text",
      "default": "New Collection"
    }
  ]
}
{% endschema %}
