<section class="shop-look section-padding">
  <div class="page-width">
    <div class="shop-look__header reveal">
      {% if section.settings.label != blank %}
        <p class="section-label" style="color: var(--color-primary);">{{ section.settings.label }}</p>
      {% endif %}
      <h2>{{ section.settings.heading | default: 'Shop the Look' }}</h2>
    </div>

    <div class="shop-look__inner reveal">
      <div class="shop-look__image">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.heading | default: 'Shop the look' | escape }}"
            loading="lazy"
            width="1200"
            height="1500"
          >
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}

        {% for block in section.blocks %}
          <button
            class="shop-look__hotspot"
            style="top: {{ block.settings.position_y }}%; left: {{ block.settings.position_x }}%;"
            data-hotspot="{{ forloop.index }}"
            aria-label="View product"
            {{ block.shopify_attributes }}
          >
            <span class="shop-look__hotspot-dot"></span>
            <span class="shop-look__hotspot-ring"></span>
          </button>

          <div class="shop-look__hotspot-card" data-hotspot-card="{{ forloop.index }}">
            {% if block.settings.product != blank %}
              {% assign hotspot_product = all_products[block.settings.product] %}
              {% if hotspot_product.featured_image %}
                <img src="{{ hotspot_product.featured_image | image_url: width: 200 }}" alt="" class="shop-look__card-image">
              {% endif %}
              <div class="shop-look__card-info">
                <p class="shop-look__card-title">{{ hotspot_product.title }}</p>
                <p class="shop-look__card-price">{{ hotspot_product.price | money }}</p>
                <a href="{{ hotspot_product.url }}" class="shop-look__card-link">View Product</a>
              </div>
            {% else %}
              <div class="shop-look__card-info">
                <p class="shop-look__card-title">{{ block.settings.title | default: 'Product Name' }}</p>
                <p class="shop-look__card-price">{{ block.settings.price | default: '$49.00' }}</p>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop the Look",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Complete the Outfit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Look"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle image"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (fallback)",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price (fallback)",
          "default": "$49.00"
        },
        {
          "type": "range",
          "id": "position_x",
          "label": "Horizontal position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "position_y",
          "label": "Vertical position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look",
      "blocks": [
        { "type": "hotspot", "settings": { "position_x": 30, "position_y": 25, "title": "Graphic Tee", "price": "$45.00" } },
        { "type": "hotspot", "settings": { "position_x": 65, "position_y": 60, "title": "Artist Joggers", "price": "$65.00" } }
      ]
    }
  ]
}
{% endschema %}
