<section class="hero">
  <div class="hero__gradient-bg"></div>

  <div class="hero__split">
    <div class="hero__text">
      {% if section.settings.subtitle != blank %}
        <p class="section-label" style="color: #00E5A0;">{{ section.settings.subtitle }}</p>
      {% endif %}

      <h1 class="hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.description != blank %}
        <p class="hero__description">{{ section.settings.description }}</p>
      {% endif %}

      <div class="hero__actions">
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--large">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
        {% if section.settings.button_text_2 != blank %}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--outline-light btn--large">
            {{ section.settings.button_text_2 }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="hero__collage">
      {% for block in section.blocks %}
        <div class="hero__collage-item hero__collage-item--{{ forloop.index }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.alt | default: 'Hero image' | escape }}"
              loading="eager"
              width="800"
              height="1000"
            >
          {% else %}
            {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if section.settings.show_scroll_hint %}
    <div class="hero__scroll-hint">
      <span></span>
      Scroll
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero banner",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Artist Series 001"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear the <em>Art</em>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Limited collections designed by independent artists. Bold apparel that tells a story."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop the Drop"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Second button text",
      "default": "Meet the Artist"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second button link"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_hint",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Collage image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
