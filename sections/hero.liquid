{% case section.settings.bg_preset %}
  {% when 'dark' %}
    {% assign hero_bg = '#1A1A1A' %}
  {% when 'black' %}
    {% assign hero_bg = '#000000' %}
  {% when 'brand' %}
    {% assign hero_bg = 'radial-gradient(ellipse at 15% 85%, rgba(255,60,0,0.2) 0%, transparent 50%), radial-gradient(ellipse at 75% 15%, rgba(91,46,255,0.25) 0%, transparent 50%), linear-gradient(160deg, #0D0D0D 0%, #1A1A2E 40%, #16213E 100%)' %}
  {% when 'custom' %}
    {% assign hero_bg = section.settings.bg_custom | default: '#1A1A1A' %}
{% endcase %}

<section class="hero">
  <div class="hero__gradient-bg" style="background: {{ hero_bg }};"></div>

  {% if section.settings.video_url != blank %}
    <div class="hero__video">
      <video autoplay muted loop playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    </div>
    <div class="hero__overlay" style="background: linear-gradient(160deg, rgba(26,26,26,0.7) 0%, rgba(26,26,26,0.4) 50%, rgba(91,46,255,0.2) 100%);"></div>
  {% endif %}

  <div class="hero__split">
    <div class="hero__text">
      {% if section.settings.subtitle != blank %}
        <p class="section-label"><span class="section-label__line" style="background:var(--color-text-light);"></span><span style="color:var(--color-primary);">{{ section.settings.subtitle }}</span></p>
      {% endif %}

      <h1 class="hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.description != blank %}
        <p class="hero__description">{{ section.settings.description }}</p>
      {% endif %}

      <div class="hero__actions">
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="btn btn--large" style="background:var(--color-primary);color:var(--color-text-light);border-color:var(--color-primary);">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
        {% if section.settings.button_text_2 != blank %}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--large" style="background:transparent;color:var(--color-text-light);border-color:rgba(255,255,255,0.7);">
            {{ section.settings.button_text_2 }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="hero__collage">
      {% for block in section.blocks %}
        <div class="hero__collage-item hero__collage-item--{{ forloop.index }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.alt | default: 'Hero image' | escape }}"
              loading="eager"
              width="800"
              height="1000"
            >
          {% else %}
            {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero banner",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "bg_preset",
      "label": "Background preset",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark grey" },
        { "value": "black", "label": "Black" },
        { "value": "brand", "label": "Brand gradient" },
        { "value": "custom", "label": "Custom" }
      ],
      "info": "Choose a preset or select Custom to enter your own"
    },
    {
      "type": "text",
      "id": "bg_custom",
      "label": "Custom background",
      "info": "Any valid CSS background value, e.g. #333 or linear-gradient(135deg, #1a1a1a, #2d1b4e)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Artist Series 001"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear the <em>Art</em>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Limited collections designed by independent artists. Bold apparel that tells a story."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop the Drop"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Second button text",
      "default": "Meet the Artist"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second button link"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_hint",
      "label": "Show scroll indicator",
      "default": true
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (mp4)",
      "info": "Upload video via Settings > Files, then paste the URL here. When set, the collage images are hidden."
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Collage image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
