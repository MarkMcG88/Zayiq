<section class="values-bar">
  <div class="values-bar__inner">
    {% for block in section.blocks %}
      <div class="values-bar__item">
        <div class="values-bar__icon">
          {% case block.settings.icon %}
            {% when 'shipping' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {% when 'quality' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2z"/></svg>
            {% when 'limited' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            {% when 'sustainable' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
          {% endcase %}
        </div>
        <p class="values-bar__text">{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Values bar",
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "quality", "label": "Quality" },
            { "value": "limited", "label": "Limited" },
            { "value": "sustainable", "label": "Sustainable" },
            { "value": "gift", "label": "Gift" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping Over $100"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Values bar",
      "blocks": [
        { "type": "value", "settings": { "icon": "shipping", "text": "Free Shipping Over $100" } },
        { "type": "value", "settings": { "icon": "quality", "text": "Premium Quality Materials" } },
        { "type": "value", "settings": { "icon": "limited", "text": "Limited Edition Drops" } },
        { "type": "value", "settings": { "icon": "sustainable", "text": "Ethically Made" } }
      ]
    }
  ]
}
{% endschema %}
