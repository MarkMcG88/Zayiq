{% if section.settings.text != blank %}
  <div class="announcement-bar" role="region" aria-label="Announcement" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
    <div class="announcement-bar__track">
      {% for i in (1..8) %}
        <span class="announcement-bar__item">
          {% if section.settings.link != blank %}
            <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
          {% else %}
            {{ section.settings.text }}
          {% endif %}
        </span>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $100 — New artist drop every month"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FF3C00"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
