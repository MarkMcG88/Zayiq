<section class="lookbook section-padding--tight reveal">
  <div class="lookbook__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="lookbook__item" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.label | default: 'Lookbook image' | escape }}"
            loading="lazy"
            width="1200"
            height="800"
          >
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        <div class="lookbook__item-overlay">
          {% if block.settings.label != blank %}
            <span class="lookbook__item-label">{{ block.settings.label }}</span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Lookbook",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop the Look"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook",
      "blocks": [
        { "type": "image", "settings": { "label": "New Arrivals" } },
        { "type": "image", "settings": { "label": "Artist Series" } },
        { "type": "image", "settings": { "label": "Essentials" } }
      ]
    }
  ]
}
{% endschema %}
