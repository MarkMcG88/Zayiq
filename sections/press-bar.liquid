<section class="press-bar section-padding--tight reveal">
  <div class="page-width">
    {% if section.settings.label != blank %}
      <p class="press-bar__label">{{ section.settings.label }}</p>
    {% endif %}
    <div class="press-bar__logos">
      {% for block in section.blocks %}
        <div class="press-bar__item" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            <img
              src="{{ block.settings.logo | image_url: width: 200 }}"
              alt="{{ block.settings.name | default: 'Press logo' | escape }}"
              loading="lazy"
              width="200"
              height="60"
            >
          {% else %}
            <span class="press-bar__name">{{ block.settings.name | default: 'Publication' }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press bar",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "As Seen In"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Publication",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name (fallback if no logo)",
          "default": "Publication"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press bar",
      "blocks": [
        { "type": "logo", "settings": { "name": "Highsnobiety" } },
        { "type": "logo", "settings": { "name": "Hypebeast" } },
        { "type": "logo", "settings": { "name": "Complex" } },
        { "type": "logo", "settings": { "name": "i-D" } },
        { "type": "logo", "settings": { "name": "Dazed" } }
      ]
    }
  ]
}
{% endschema %}
