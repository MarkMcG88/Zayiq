<section class="countdown section-padding" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="page-width">
    <div class="countdown__inner">
      {% if section.settings.label != blank %}
        <p class="section-label" style="color: {{ section.settings.accent_color }};">{{ section.settings.label }}</p>
      {% endif %}

      <h2 class="countdown__title">{{ section.settings.heading | default: 'Next Drop' }}</h2>

      {% if section.settings.description != blank %}
        <p class="countdown__desc">{{ section.settings.description }}</p>
      {% endif %}

      <div class="countdown__timer" data-countdown="{{ section.settings.date }}">
        <div class="countdown__unit">
          <span class="countdown__number" data-days>00</span>
          <span class="countdown__label">Days</span>
        </div>
        <div class="countdown__separator">:</div>
        <div class="countdown__unit">
          <span class="countdown__number" data-hours>00</span>
          <span class="countdown__label">Hours</span>
        </div>
        <div class="countdown__separator">:</div>
        <div class="countdown__unit">
          <span class="countdown__number" data-minutes>00</span>
          <span class="countdown__label">Min</span>
        </div>
        <div class="countdown__separator">:</div>
        <div class="countdown__unit">
          <span class="countdown__number" data-seconds>00</span>
          <span class="countdown__label">Sec</span>
        </div>
      </div>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--large" style="margin-top: 32px;">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Countdown timer",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Coming Soon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Next Drop"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "date",
      "label": "Countdown date (YYYY-MM-DD HH:MM)",
      "default": "2026-05-01 00:00",
      "info": "Format: 2026-05-01 00:00"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get Notified"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#FF3C00"
    }
  ],
  "presets": [
    {
      "name": "Countdown timer"
    }
  ]
}
{% endschema %}
