<article class="article-page section-padding">
  <div class="page-width">
    <div class="article-page__header">
      {% if article.tags.size > 0 %}
        <span class="article-page__tag">{{ article.tags.first }}</span>
      {% endif %}
      <h1 class="article-page__title">{{ article.title }}</h1>
      <p class="article-page__meta">{{ article.published_at | date: '%B %d, %Y' }} &middot; {{ article.author }}</p>
    </div>

    {% if article.image %}
      <div class="article-page__image">
        <img
          src="{{ article.image | image_url: width: 1920 }}"
          alt="{{ article.image.alt | default: article.title }}"
          loading="eager"
          width="1920"
          height="1080"
        >
      </div>
    {% endif %}

    <div class="article-page__content rte">
      {{ article.content }}
    </div>

    {% if blog.comments_enabled? %}
      <div style="max-width: 720px; margin: 60px auto 0;">
        <h3 style="margin-bottom: 24px;">{{ article.comments_count }} {{ article.comments_count | pluralize: 'Comment', 'Comments' }}</h3>

        {% for comment in article.comments %}
          <div style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid #e0e0e0;">
            <p style="font-weight: 600; margin-bottom: 4px;">{{ comment.author }}</p>
            <p style="font-size: 0.8125rem; opacity: 0.5; margin-bottom: 12px;">{{ comment.created_at | date: '%B %d, %Y' }}</p>
            <div>{{ comment.content }}</div>
          </div>
        {% endfor %}

        {% form 'new_comment', article %}
          <div style="display: grid; gap: 16px; margin-top: 32px;">
            <h4>Leave a comment</h4>
            <input type="text" name="comment[author]" placeholder="Name" required style="padding: 12px 16px; border: 2px solid #e0e0e0; border-radius: var(--radius);">
            <input type="email" name="comment[email]" placeholder="Email" required style="padding: 12px 16px; border: 2px solid #e0e0e0; border-radius: var(--radius);">
            <textarea name="comment[body]" placeholder="Your comment..." required rows="4" style="padding: 12px 16px; border: 2px solid #e0e0e0; border-radius: var(--radius); resize: vertical;"></textarea>
            <button type="submit" class="btn btn--primary">Post Comment</button>
          </div>
        {% endform %}
      </div>
    {% endif %}
  </div>
</article>
