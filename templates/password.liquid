<section class="password-page">
  <div class="password-page__content">
    <div class="password-page__logo">
      {% if settings.logo %}
        <img src="{{ settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="300">
      {% else %}
        <h1 class="password-page__shop-name">{{ shop.name }}</h1>
      {% endif %}
    </div>

    <h2 class="password-page__heading">We're Coming Soon</h2>

    {% if shop.password_message != blank %}
      <div class="password-page__message rte">
        {{ shop.password_message }}
      </div>
    {% endif %}

    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}

      <div class="password-page__form">
        <input
          type="password"
          name="password"
          id="Password"
          class="form-input"
          placeholder="Enter store password"
          required
        >
        <button type="submit" class="btn btn--primary">Enter</button>
      </div>
    {% endform %}

    <div class="password-page__footer">
      <p>Are you the store owner? <a href="/admin">Log in here</a></p>
    </div>
  </div>
</section>
