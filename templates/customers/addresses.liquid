<section class="account-page section-padding">
  <div class="page-width">
    <div class="account-dashboard">
      <div class="account-dashboard__header">
        <h1>My Addresses</h1>
        <button class="btn btn--primary" id="AddAddressToggle">Add New Address</button>
      </div>

      <div id="AddAddressForm" class="account-address-form" style="display: none;">
        <h3 style="margin-bottom: 24px;">New Address</h3>
        {% form 'customer_address', customer.new_address %}
          {% include 'address-fields' %}
          <div class="form-actions">
            <button type="submit" class="btn btn--primary">Save Address</button>
            <button type="button" class="btn btn--outline" id="AddAddressCancel">Cancel</button>
          </div>
        {% endform %}
      </div>

      {% if customer.addresses.size == 0 %}
        <div class="account-empty">
          <p>You haven't saved any addresses yet.</p>
        </div>
      {% else %}
        <div class="grid grid--3" style="margin-top: 32px;">
          {% for address in customer.addresses %}
            <div class="account-address-card">
              {% if address == customer.default_address %}
                <span class="account-badge" style="margin-bottom: 12px;">Default</span>
              {% endif %}
              <p><strong>{{ address.first_name }} {{ address.last_name }}</strong></p>
              <p>{{ address.address1 }}</p>
              {% if address.address2 != blank %}<p>{{ address.address2 }}</p>{% endif %}
              <p>{{ address.city }}, {{ address.province_code }} {{ address.zip }}</p>
              <p>{{ address.country }}</p>
              {% if address.phone != blank %}<p>{{ address.phone }}</p>{% endif %}

              <div class="account-address-card__actions">
                <a href="/account/addresses/{{ address.id }}/edit" class="account-address-card__action">Edit</a>
                {% unless address == customer.default_address %}
                  <button type="button" class="account-address-card__action" onclick="Shopify.postLink('/account/addresses/{{ address.id }}', {parameters: {'_method': 'delete'}, message: 'Are you sure you want to delete this address?'})">
                    Delete
                  </button>
                {% endunless %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function() {
    var toggle = document.getElementById('AddAddressToggle');
    var cancel = document.getElementById('AddAddressCancel');
    var form = document.getElementById('AddAddressForm');

    if (toggle && form) {
      toggle.addEventListener('click', function() { form.style.display = 'block'; toggle.style.display = 'none'; });
    }
    if (cancel && form) {
      cancel.addEventListener('click', function() { form.style.display = 'none'; toggle.style.display = ''; });
    }
  })();
</script>
