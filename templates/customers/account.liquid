<section class="account-page section-padding">
  <div class="page-width">
    <div class="account-dashboard">
      <div class="account-dashboard__header">
        <div>
          <h1>My Account</h1>
          <p class="account-dashboard__greeting">Welcome back, {{ customer.first_name }}</p>
        </div>
        <a href="/account/logout" class="btn btn--outline">Sign Out</a>
      </div>

      <div class="account-dashboard__grid">
        <div class="account-dashboard__sidebar">
          <nav class="account-nav">
            <a href="/account" class="account-nav__link is-active">Order History</a>
            <a href="/account/addresses" class="account-nav__link">Addresses</a>
          </nav>

          <div class="account-dashboard__info">
            <h4>Account Details</h4>
            <p>{{ customer.name }}</p>
            <p>{{ customer.email }}</p>
            {% if customer.default_address %}
              <p style="margin-top: 8px; opacity: 0.6;">
                {{ customer.default_address.city }},
                {{ customer.default_address.province_code }}
                {{ customer.default_address.country_code }}
              </p>
            {% endif %}
          </div>
        </div>

        <div class="account-dashboard__content">
          <h2 style="font-size: 1.25rem; margin-bottom: 24px;">Order History</h2>

          {% if customer.orders.size == 0 %}
            <div class="account-empty">
              <p>You haven't placed any orders yet.</p>
              <a href="/collections/all" class="btn btn--primary">Start Shopping</a>
            </div>
          {% else %}
            <table class="account-table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                {% for order in customer.orders %}
                  <tr>
                    <td><a href="{{ order.customer_url }}" class="account-table__link">{{ order.name }}</a></td>
                    <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                    <td>
                      <span class="account-badge">{{ order.fulfillment_status_label }}</span>
                    </td>
                    <td>{{ order.total_price | money }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
