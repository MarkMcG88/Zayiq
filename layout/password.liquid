<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>{{ page_title }}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {% endif %}

  {% assign header_font_set = false %}
  {% assign body_font_set = false %}
  {% if settings.type_header_font.family %}
    {{ settings.type_header_font | font_face: font_display: 'swap' }}
    {% assign header_bold = settings.type_header_font | font_modify: 'weight', 'bold' %}
    {% assign header_semi = settings.type_header_font | font_modify: 'weight', '600' %}
    {% if header_bold %}{{ header_bold | font_face: font_display: 'swap' }}{% endif %}
    {% if header_semi %}{{ header_semi | font_face: font_display: 'swap' }}{% endif %}
    {% assign header_font_set = true %}
  {% endif %}
  {% if settings.type_body_font.family %}
    {{ settings.type_body_font | font_face: font_display: 'swap' }}
    {% assign body_medium = settings.type_body_font | font_modify: 'weight', '500' %}
    {% assign body_semi = settings.type_body_font | font_modify: 'weight', '600' %}
    {% if body_medium %}{{ body_medium | font_face: font_display: 'swap' }}{% endif %}
    {% if body_semi %}{{ body_semi | font_face: font_display: 'swap' }}{% endif %}
    {% assign body_font_set = true %}
  {% endif %}
  {% unless header_font_set and body_font_set %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  {% endunless %}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body class="template-password">
  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>
</body>
</html>
