<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {% endif %}

  {% comment %} Load fonts — use Shopify font picker if set, otherwise Google Fonts {% endcomment %}
  {% assign header_font_set = false %}
  {% assign body_font_set = false %}
  {% if settings.type_header_font.family %}
    <style>
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
      {% assign header_bold = settings.type_header_font | font_modify: 'weight', 'bold' %}
      {% assign header_semi = settings.type_header_font | font_modify: 'weight', '600' %}
      {% if header_bold %}{{ header_bold | font_face: font_display: 'swap' }}{% endif %}
      {% if header_semi %}{{ header_semi | font_face: font_display: 'swap' }}{% endif %}
    </style>
    {% assign header_font_set = true %}
  {% endif %}
  {% if settings.type_body_font.family %}
    <style>
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {% assign body_medium = settings.type_body_font | font_modify: 'weight', '500' %}
      {% assign body_semi = settings.type_body_font | font_modify: 'weight', '600' %}
      {% if body_medium %}{{ body_medium | font_face: font_display: 'swap' }}{% endif %}
      {% if body_semi %}{{ body_semi | font_face: font_display: 'swap' }}{% endif %}
    </style>
    {% assign body_font_set = true %}
  {% endif %}
  {% unless header_font_set and body_font_set %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  {% endunless %}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  <style>
    {%- case settings.button_style -%}
      {%- when 'rounded' -%}{%- assign btn_radius = '6px' -%}
      {%- when 'pill' -%}{%- assign btn_radius = '999px' -%}
      {%- else -%}{%- assign btn_radius = '0' -%}
    {%- endcase -%}
    {%- case settings.card_border_radius -%}
      {%- when 'none' -%}{%- assign card_r = '0' -%}{%- assign card_r_lg = '0' -%}
      {%- when 'medium' -%}{%- assign card_r = '8px' -%}{%- assign card_r_lg = '12px' -%}
      {%- when 'large' -%}{%- assign card_r = '12px' -%}{%- assign card_r_lg = '20px' -%}
      {%- else -%}{%- assign card_r = '4px' -%}{%- assign card_r_lg = '8px' -%}
    {%- endcase -%}
    {%- if settings.enable_animations == false -%}
      {%- assign tr = '0s' -%}{%- assign tr_slow = '0s' -%}
    {%- else -%}
      {%- case settings.animation_speed -%}
        {%- when 'fast' -%}{%- assign tr = '0.15s cubic-bezier(0.4, 0, 0.2, 1)' -%}{%- assign tr_slow = '0.3s cubic-bezier(0.4, 0, 0.2, 1)' -%}
        {%- when 'slow' -%}{%- assign tr = '0.5s cubic-bezier(0.4, 0, 0.2, 1)' -%}{%- assign tr_slow = '0.9s cubic-bezier(0.4, 0, 0.2, 1)' -%}
        {%- else -%}{%- assign tr = '0.3s cubic-bezier(0.4, 0, 0.2, 1)' -%}{%- assign tr_slow = '0.6s cubic-bezier(0.4, 0, 0.2, 1)' -%}
      {%- endcase -%}
    {%- endif -%}
    :root {
      --color-primary: {{ settings.color_primary | default: '#FF3C00' }};
      --color-secondary: {{ settings.color_secondary | default: '#5B2EFF' }};
      --color-accent: {{ settings.color_accent | default: '#00E5A0' }};
      --color-bg: {{ settings.color_background | default: '#FFFFFF' }};
      --color-text: {{ settings.color_text | default: '#1A1A1A' }};
      --color-text-light: {{ settings.color_text_light | default: '#FFFFFF' }};
      --color-surface: {{ settings.color_surface | default: '#F5F5F3' }};
      --color-border: {{ settings.color_border | default: '#E2E2E0' }};
      --color-primary-hover: {{ settings.color_primary_hover | default: '#E03500' }};
      --color-secondary-hover: {{ settings.color_secondary_hover | default: '#4A1FE0' }};
      --color-success: {{ settings.color_success | default: '#00A870' }};
      --color-error: {{ settings.color_error | default: '#e53e3e' }};
      {% if settings.type_header_font.family %}
        --font-heading: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
      {% else %}
        --font-heading: 'Space Grotesk', sans-serif;
      {% endif %}
      {% if settings.type_body_font.family %}
        --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
      {% else %}
        --font-body: 'Inter', sans-serif;
      {% endif %}
      --font-heading-weight: {{ settings.heading_weight | default: '700' }};
      --heading-transform: {{ settings.heading_transform | default: 'uppercase' }};
      --body-font-size: {{ settings.body_font_size | default: 16 }}px;
      --body-line-height: {{ settings.body_line_height | default: '1.6' }};
      --max-width: {{ settings.max_page_width | default: 1440 }}px;
      --gutter: clamp(16px, 3vw, 40px);
      --section-spacing: {{ settings.section_vertical_spacing | default: 60 }}px;
      --grid-gap: {{ settings.grid_gap | default: 20 }}px;
      --btn-radius: {{ btn_radius }};
      --btn-transform: {{ settings.button_transform | default: 'uppercase' }};
      --radius: {{ card_r }};
      --radius-lg: {{ card_r_lg }};
      --transition: {{ tr }};
      --transition-slow: {{ tr_slow }};
      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    }
  </style>

  {{ content_for_header }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    var Zayiq = {
      routes: {
        search_url: '{{ routes.search_url }}',
        cart_url: '{{ routes.cart_url }}'
      }
    };
  </script>
</head>
<body class="template-{{ template.name }}">
  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  {% render 'predictive-search' %}
  {% render 'cart-drawer' %}
  {% render 'quick-view' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Back to top -->
  <button class="back-to-top" id="BackToTop" aria-label="Back to top" style="display: none;">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
