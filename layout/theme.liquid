<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {% endif %}

  {% comment %} Load fonts from Shopify font picker {% endcomment %}
  {{ settings.type_header_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_face: font_display: 'swap' }}

  {% assign header_bold = settings.type_header_font | font_modify: 'weight', 'bold' %}
  {% assign header_semi = settings.type_header_font | font_modify: 'weight', '600' %}
  {% assign body_medium = settings.type_body_font | font_modify: 'weight', '500' %}
  {% assign body_semi = settings.type_body_font | font_modify: 'weight', '600' %}
  {% if header_bold %}{{ header_bold | font_face: font_display: 'swap' }}{% endif %}
  {% if header_semi %}{{ header_semi | font_face: font_display: 'swap' }}{% endif %}
  {% if body_medium %}{{ body_medium | font_face: font_display: 'swap' }}{% endif %}
  {% if body_semi %}{{ body_semi | font_face: font_display: 'swap' }}{% endif %}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    var Zayiq = {
      routes: {
        search_url: '{{ routes.search_url }}',
        cart_url: '{{ routes.cart_url }}'
      }
    };
  </script>
</head>
<body class="template-{{ template.name }}">
  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  {% render 'predictive-search' %}
  {% render 'cart-drawer' %}
  {% render 'quick-view' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Back to top -->
  <button class="back-to-top" id="BackToTop" aria-label="Back to top" style="display: none;">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
